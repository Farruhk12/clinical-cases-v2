# 1) В Supabase: SQL Editor — вставь целиком supabase/full_setup.sql → Run
# 2) DATABASE_URL — из Supabase → Settings → Database → Connection string.
#    Если локально видишь getaddrinfo ENOENT / не коннектится: прямой хост db.*.supabase.co:5432
#    иногда резолвится только в IPv6. Используй «Session pooler» или «Transaction» (порт 6543) — там обычно есть IPv4.
# 3) AUTH_SECRET — случайная длинная строка (без этого сессии ломаются)

# Пример pooler (подставь регион/реф из дашборда; пароль — тот же, что у postgres):
# DATABASE_URL="postgresql://postgres.REF:ПАРОЛЬ@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require"

DATABASE_URL="postgresql://postgres:ПАРОЛЬ@db.REF.supabase.co:5432/postgres?sslmode=require"
AUTH_SECRET=""

# Порт API. npm run dev сам подберёт свободный, если PORT занят, и синхронизирует прокси Vite (VITE_DEV_API_PORT).
PORT=3001

# Vercel: в Project → Settings → Environment Variables добавьте те же DATABASE_URL и AUTH_SECRET,
# что в локальном .env (Supabase pooler URI надёжнее на сервере Vercel, чем прямой db.*:5432).
# Проверка после деплоя: откройте в браузере https://ваш-проект.vercel.app/api/health
# → {"ok":true,"db":true} если API и БД на месте.
#
# Важно: фронт (React) НЕ подключается к Supabase SDK и НЕ использует NEXT_PUBLIC_SUPABASE_URL.
# Данные: браузер → только запросы на тот же домен /api/... → serverless Express → postgres(DATABASE_URL).
# В Vercel в разделе Environment Variables критичны именно DATABASE_URL и AUTH_SECRET (как в .env).
# NEXT_PUBLIC_SUPABASE_URL в текущем коде нигде не читается — можно не задавать.

GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
